# Database Connection URL (e.g. Neon, Supabase, local PostgreSQL, or Docker Compose)
# For local Docker Compose Postgres:
DATABASE_URL="postgresql://postgres:password@localhost:5432/task_management?schema=public"

# Secure JWT Token Secret Key for Authentication
JWT_SECRET="generate_a_secure_random_string_here_at_least_32_characters"

# Port (defaults to 3000)
PORT=3000
